# Telegram MTProto credentials — get from https://my.telegram.org
# Required. The UserBot logs in as your own account on first `pnpm run start`.
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Where the mtcute session is persisted. Optional, defaults to mtcute.session.
# Keep this file private — it grants full access to the logged-in account.
TELEGRAM_SESSION_FILE=mtcute.session

# OpenAI-compatible translation provider.
# OAI_API_KEY is required for translation; without it the bot still logs in
# but translation features are disabled.
OAI_API_KEY=sk-xxxxx
# OAI_BASE_URL defaults to https://api.deepseek.com. Override for other providers.
OAI_BASE_URL=https://api.deepseek.com
# OAI_MODEL defaults to deepseek-v4-flash.
OAI_MODEL=deepseek-v4-flash

# libSQL/SQLite database for per-chat settings. Required.
DB_FILE_NAME=file:group.db

# Log verbosity: debug | info | warn | error. Optional, defaults to info.
# Only `debug` prints full message text; info and above redact user content
# to a character count for privacy.
LOG_LEVEL=info
